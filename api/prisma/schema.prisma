generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String    @id @default(uuid()) @db.Uuid
  email       String    @unique @db.VarChar(255)
  name        String    @db.VarChar(100)
  nickname    String?   @db.VarChar(50)
  onboardedAt DateTime? @map("onboarded_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  credentials        Credential[]
  sessions           Session[]
  oauthAccounts      OAuthAccount[]
  passkeyCredentials PasskeyCredential[]
  authAuditLogs      AuthAuditLog[]
  assistantProfile   AssistantProfile?
  bankAccounts       UserBankAccount[]
  categories         Category[]
  transactions       Transaction[]
  transfers          Transfer[]
  installmentGroups  InstallmentGroup[]

  @@map("users")
}

enum TreatmentStyle {
  formal
  informal
  very_informal

  @@map("treatment_style")
}

model AssistantProfile {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String         @unique @map("user_id") @db.Uuid
  treatmentStyle TreatmentStyle @default(informal) @map("treatment_style")
  voiceId        String         @map("voice_id") @db.VarChar(255)
  avatarUrl      String?        @map("avatar_url") @db.VarChar(500)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("assistant_profiles")
}

enum CredentialType {
  password

  @@map("credential_type")
}

model Credential {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String         @map("user_id") @db.Uuid
  type      CredentialType
  hash      String
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("credentials")
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @unique @map("refresh_token_hash")
  userAgent        String?   @map("user_agent")
  ip               String?   @db.Inet
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

enum OAuthProvider {
  google

  @@map("oauth_provider")
}

model OAuthAccount {
  id         String        @id @default(uuid()) @db.Uuid
  userId     String        @map("user_id") @db.Uuid
  provider   OAuthProvider
  providerId String        @map("provider_id")
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
  @@map("oauth_accounts")
}

enum AuthAuditEvent {
  login_success
  login_failure
  passkey_enrolled
  oauth_linked
  password_changed
  all_sessions_revoked

  @@map("auth_audit_event")
}

model AuthAuditLog {
  id        String         @id @default(uuid()) @db.Uuid
  event     AuthAuditEvent
  userId    String?        @map("user_id") @db.Uuid
  ip        String?        @db.Inet
  userAgent String?        @map("user_agent")
  context   Json?          @db.JsonB
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([event])
  @@index([createdAt])
  @@map("auth_audit_log")
}

model PasskeyCredential {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  credentialId String    @unique @map("credential_id")
  publicKey    Bytes     @map("public_key")
  counter      BigInt    @default(0)
  transports   String[]
  deviceType   String?   @map("device_type")
  backedUp     Boolean?  @map("backed_up")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  lastUsedAt   DateTime? @map("last_used_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("passkey_credentials")
}

enum TransactionType {
  expense
  income

  @@map("transaction_type")
}

enum InvoiceStatus {
  open
  closed
  paid
  overdue

  @@map("invoice_status")
}

model Bank {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(100)
  compeCode String   @unique @map("compe_code") @db.VarChar(10)
  logoUrl   String?  @map("logo_url") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  accounts UserBankAccount[]

  @@map("banks")
}

model UserBankAccount {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  bankId         String   @map("bank_id") @db.Uuid
  nickname       String   @db.VarChar(80)
  balance        Decimal  @default(0) @db.Decimal(15, 2)
  creditLimit    Decimal? @map("credit_limit") @db.Decimal(15, 2)
  overdraftLimit Decimal? @map("overdraft_limit") @db.Decimal(15, 2)
  closeDay       Int?     @map("close_day") @db.SmallInt
  dueDay         Int?     @map("due_day") @db.SmallInt
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  bank Bank @relation(fields: [bankId], references: [id], onDelete: Restrict)

  transactions      Transaction[]
  transfersFrom     Transfer[]          @relation("TransferFromAccount")
  transfersTo       Transfer[]          @relation("TransferToAccount")
  invoices          CreditCardInvoice[]
  installmentGroups InstallmentGroup[]

  @@index([userId])
  @@index([bankId])
  @@map("user_bank_accounts")
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  name      String   @db.VarChar(80)
  icon      String?  @db.VarChar(50)
  color     String?  @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user              User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions      Transaction[]
  installmentGroups InstallmentGroup[]

  @@index([userId])
  @@map("categories")
}

model Transaction {
  id                  String          @id @default(uuid()) @db.Uuid
  userId              String          @map("user_id") @db.Uuid
  accountId           String          @map("account_id") @db.Uuid
  categoryId          String?         @map("category_id") @db.Uuid
  invoiceId           String?         @map("invoice_id") @db.Uuid
  installmentGroupId  String?         @map("installment_group_id") @db.Uuid
  installmentNumber   Int?            @map("installment_number") @db.SmallInt
  type                TransactionType
  amount              Decimal         @db.Decimal(15, 2)
  description         String?         @db.VarChar(255)
  occurredAt          DateTime        @map("occurred_at") @db.Timestamptz
  createdAt           DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  account          UserBankAccount    @relation(fields: [accountId], references: [id], onDelete: Restrict)
  category         Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  invoice          CreditCardInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  installmentGroup InstallmentGroup?  @relation(fields: [installmentGroupId], references: [id], onDelete: Restrict)

  @@index([userId, occurredAt])
  @@index([accountId])
  @@index([categoryId])
  @@index([invoiceId])
  @@index([installmentGroupId])
  @@map("transactions")
}

model Transfer {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  fromAccountId String   @map("from_account_id") @db.Uuid
  toAccountId   String   @map("to_account_id") @db.Uuid
  amount        Decimal  @db.Decimal(15, 2)
  description   String?  @db.VarChar(255)
  occurredAt    DateTime @map("occurred_at") @db.Timestamptz
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromAccount UserBankAccount @relation("TransferFromAccount", fields: [fromAccountId], references: [id], onDelete: Restrict)
  toAccount   UserBankAccount @relation("TransferToAccount", fields: [toAccountId], references: [id], onDelete: Restrict)

  invoicesPaid CreditCardInvoice[]

  @@index([userId, occurredAt])
  @@index([fromAccountId])
  @@index([toAccountId])
  @@map("transfers")
}

model CreditCardInvoice {
  id                String        @id @default(uuid()) @db.Uuid
  accountId         String        @map("account_id") @db.Uuid
  status            InvoiceStatus @default(open)
  cycleStart        DateTime      @map("cycle_start") @db.Date
  cycleEnd          DateTime      @map("cycle_end") @db.Date
  dueDate           DateTime      @map("due_date") @db.Date
  totalAmount       Decimal       @default(0) @map("total_amount") @db.Decimal(15, 2)
  closedAt          DateTime?     @map("closed_at") @db.Timestamptz
  paidAt            DateTime?     @map("paid_at") @db.Timestamptz
  paidViaTransferId String?       @unique @map("paid_via_transfer_id") @db.Uuid
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  account         UserBankAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  paidViaTransfer Transfer?       @relation(fields: [paidViaTransferId], references: [id], onDelete: SetNull)

  transactions Transaction[]

  @@unique([accountId, cycleStart])
  @@index([accountId, status])
  @@index([status])
  @@map("credit_card_invoices")
}

// Represents a purchase split into N installments on a credit card.
// Materializes N Transaction rows (one per parcel), each linked back via
// installmentGroupId + installmentNumber. Cancellation deletes them all
// atomically via the app layer (see MNT-156).
// Invariants enforced at DB level (deferred SQL): if either
// installment_group_id OR installment_number is NOT NULL on transactions,
// the other must be too; installments_count >= 2 (a single-parcel
// "purchase" is a regular transaction, not an installment plan).
model InstallmentGroup {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  accountId         String   @map("account_id") @db.Uuid
  categoryId        String?  @map("category_id") @db.Uuid
  totalAmount       Decimal  @map("total_amount") @db.Decimal(15, 2)
  installmentsCount Int      @map("installments_count") @db.SmallInt
  installmentAmount Decimal  @map("installment_amount") @db.Decimal(15, 2)
  description       String?  @db.VarChar(255)
  purchaseDate      DateTime @map("purchase_date") @db.Timestamptz
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  UserBankAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)
  category Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  installments Transaction[]

  @@index([userId])
  @@index([accountId])
  @@map("installment_groups")
}
